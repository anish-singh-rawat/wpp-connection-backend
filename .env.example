# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate a strong random key: openssl rand -hex 32
API_KEY=your-strong-secret-key-here

# ─── WhatsApp Session ─────────────────────────────────────────────────────────
WA_SESSION=default-session
SESSION_PATH=/home/ubuntu/whatsapp-api/sessions

# ─── Messaging Tuning (optional) ──────────────────────────────────────────────
MSG_MIN_DELAY=5000
MSG_MAX_DELAY=10000
MSG_MAX_RETRIES=2
MSG_RETRY_DELAY=3000

# ─── Rate Limiting (optional) ─────────────────────────────────────────────────
RATE_LIMIT_MAX=30
