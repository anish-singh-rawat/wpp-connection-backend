  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.23",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parse": "^5.5.3",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "mime-types": "^2.1.35",
    "mongoose": "9.6.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "socket.io": "4.8.1",
    "uuid": "^11.1.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
